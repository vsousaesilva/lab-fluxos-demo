    "db:migrate:local": "wrangler d1 migrations apply lab-fluxos --local",
    "db:migrate:remote": "wrangler d1 migrations apply lab-fluxos --remote",
    "db:studio": "drizzle-kit studio",
    "ingest:flows": "tsx seed/ingest-pje-flows.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.0.0",
